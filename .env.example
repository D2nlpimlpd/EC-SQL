# BoyueSQL generic configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SQL_MODEL=qwen3-vl:8b
OLLAMA_EMBEDDING_MODEL=qwen3-vl:8b

# Server benchmark model matrix.  BASELINE_MODELS is preserved per RUN_ID
# in artifacts/server_runs/<RUN_ID>/run_config.env and each model writes
# a separate JSON artifact, so repeated/resumed runs do not overwrite prior
# results.
BOYUESQL_MODELS=qwen3-vl:8b
BASELINE_MODELS=qwen2.5-coder:7b,sqlcoder:7b
DBT_EDIT_MODELS=qwen3-vl:8b

# HuggingFace snapshots downloaded by `bash scripts/one_click_linux.sh setup`
# and `bash scripts/one_click_linux.sh models`.
HF_HOME=/data/huggingface
HF_BASELINE_MODELS=NumbersStation/nsql-6B,deepseek-ai/deepseek-coder-6.7b-instruct
HF_EXTRA_MODELS=
HF_SKIP_DOWNLOAD=0
HF_DOWNLOAD_WARN_ONLY=0
SETUP_SKIP_MODELS=0

# Generic dialect: sqlite, duckdb, postgres, oracle, snowflake, bigquery, or generic.
BOYUESQL_DIALECT=sqlite
APP_ENTRY=boyuesql_service.py
HOST=0.0.0.0
PORT=5000

# Dataset and benchmark roots.
DATASET_ROOT=/data/text2sql_datasets
SPIDER2_ROOT=/data/text2sql_datasets/Spider2

# Optional database connection fields.  Keep secrets in .env, not in source.
DB_DRIVER=
DB_HOST=
DB_PORT=
DB_SERVICE_NAME=
DB_DATABASE=
DB_PATH=
DB_USER=
DB_PASSWORD=

# Oracle only, if BOYUESQL_DIALECT=oracle.
ORACLE_CLIENT_DIR=

# Schema dictionary source.  Can be JSON or SQLite DB for generic loaders.
SCHEMA_DICTIONARY_PATH=
DATA_DICT_PATH=
RAG_CACHE_DIR=./rag_cache
MAX_ROWS=500
